# ============================================================
# RÈGLES SURICATA — BLUE TEAM SECUREBANK
# Fichier : /etc/suricata/rules/local.rules
# ============================================================

# --- Détection Nmap ---
alert tcp any any -> $HOME_NET any (msg:"NMAP SCAN DETECTED"; flags:S; threshold: type both, track by_src, count 20, seconds 3; classtype:network-scan; sid:1000001; rev:1;)

# --- Détection ARP Spoofing (Bettercap) ---
alert arp any any -> any any (msg:"ARP SPOOFING DETECTED"; arp.opcode:2; threshold: type both, track by_src, count 10, seconds 5; sid:1000002; rev:1;)

# --- Tentatives de connexion SMB ---
alert tcp any any -> $HOME_NET 445 (msg:"SMB LOGIN ATTEMPT"; content:"|FF|SMB"; classtype:attempted-user; sid:1000003; rev:1;)

# --- EternalBlue exploit ---
alert tcp any any -> $HOME_NET 445 (msg:"ETERNALBLUE EXPLOIT ATTEMPT"; content:"|00 00 00 90|"; depth:8; classtype:attempted-admin; sid:1000004; rev:1;)

# --- Injection SQL sur le portail bancaire ---
alert http any any -> $HOME_NET 5000 (msg:"SQL INJECTION ATTEMPT ON BANK PORTAL"; content:"OR"; nocase; content:"1=1"; nocase; classtype:web-application-attack; sid:1000005; rev:1;)

# --- Scan de port SYN flood ---
alert tcp any any -> $HOME_NET any (msg:"SYN FLOOD DETECTED"; flags:S,!A; threshold: type both, track by_src, count 100, seconds 5; classtype:attempted-dos; sid:1000006; rev:1;)
